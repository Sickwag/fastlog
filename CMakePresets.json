{
	"version": 8,
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"displayName": "GCC x86_64-linux-gnu",
			"description": "使用编译器：C = /usr/bin/gcc, CXX = /usr/bin/g++",
			"binaryDir": "${sourceDir}/out/build/${presetName}",
			"cacheVariables": {
				"CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
				"CMAKE_C_COMPILER": "/usr/bin/gcc",
				"CMAKE_CXX_COMPILER": "/usr/bin/g++",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		},
		{
			"name": "debug",
			"displayName": "Debug",
			"description": "Debug 构建，包含调试符号",
			"inherits": "base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_CXX_FLAGS": "-g -O0"
			}
		},
		{
			"name": "release",
			"displayName": "Release",
			"description": "O3 optimize release",
			"inherits": "base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_CXX_FLAGS": "-O3 -DNDEBUG"
			}
		},
		{
			"name": "relwithdebinfo",
			"displayName": "RelWithDebInfo",
			"description": "O2 release with debug info",
			"inherits": "base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"CMAKE_CXX_FLAGS": "-O2 -g"
			}
		}
	],
	"buildPresets": [
		{
			"name": "debug",
			"configurePreset": "debug"
		},
		{
			"name": "release",
			"configurePreset": "release"
		},
		{
			"name": "relwithdebinfo",
			"configurePreset": "relwithdebinfo"
		}
	],
	"testPresets": [
		{
			"name": "debug",
			"configurePreset": "debug"
		},
		{
			"name": "release",
			"configurePreset": "release"
		},
		{
			"name": "relwithdebinfo",
			"configurePreset": "relwithdebinfo"
		}
	]
}